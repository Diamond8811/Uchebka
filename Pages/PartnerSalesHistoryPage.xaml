<Page x:Class="Uchebka.Pages.PartnerSalesHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchebka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="История реализации продукции">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding PartnerName, StringFormat='История продаж партнёра: {0}'}" FontSize="24" Margin="10" HorizontalAlignment="Center"/>

        <ListView x:Name="SalesListView" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Наименование продукции" Width="250" DisplayMemberBinding="{Binding ProductName}"/>
                    <GridViewColumn Header="Количество" Width="100" DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Дата продажи" Width="150" DisplayMemberBinding="{Binding SaleDate, StringFormat='dd.MM.yyyy'}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Button Grid.Row="2" Content="Назад" HorizontalAlignment="Center" Margin="10" Click="BackButton_Click"/>
    </Grid>
</Page>
