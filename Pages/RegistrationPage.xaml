<Page x:Class="Uchebka.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="700"
      Background="White"
      Title="Регистрация">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Подтверждение пароля:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Имя:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата рождения:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Серия паспорта:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Номер паспорта:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Семейное положение:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Состояние здоровья:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="11" Grid.Column="0" Text="Должность:" VerticalAlignment="Center"/>

        <TextBox Grid.Row="0" Grid.Column="1" Name="txtLogin" Width="250" HorizontalAlignment="Left"/>
        <PasswordBox Grid.Row="1" Grid.Column="1" Name="txtPassword" Width="250" HorizontalAlignment="Left"/>
        <PasswordBox Grid.Row="2" Grid.Column="1" Name="txtConfirmPassword" Width="250" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="txtLastName" Width="250" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="4" Grid.Column="1" Name="txtFirstName" Width="250" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="5" Grid.Column="1" Name="txtMiddleName" Width="250" HorizontalAlignment="Left"/>
        <DatePicker Grid.Row="6" Grid.Column="1" Name="dpBirthDate" Width="250" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="7" Grid.Column="1" Name="txtPassportSeries" Width="250" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="8" Grid.Column="1" Name="txtPassportNumber" Width="250" HorizontalAlignment="Left"/>
        <ComboBox Grid.Row="9" Grid.Column="1" Name="cbMaritalStatus" Width="250" HorizontalAlignment="Left" DisplayMemberPath="Name"/>
        <ComboBox Grid.Row="10" Grid.Column="1" Name="cbHealthStatus" Width="250" HorizontalAlignment="Left" DisplayMemberPath="Name"/>
        <ComboBox Grid.Row="11" Grid.Column="1" Name="cbPosition" Width="250" HorizontalAlignment="Left" DisplayMemberPath="Name"/>

        <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Name="btnBack" Content="Назад" Width="120" Click="Back_Click" Margin="5" Background="Red"/>
            <Button Name="btnRegister" Content="Зарегистрироваться" Width="200" Click="Register_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>