<Page x:Class="Uchebka.Pages.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchebka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Главное меню">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добро пожаловать!" 
                   FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <Button Content="Список партнёров" Width="200" Height="50" Margin="10" Click="PartnersButton_Click"/>
            <Button Content="Выход" Width="200" Height="50" Margin="10" Click="LogoutButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
