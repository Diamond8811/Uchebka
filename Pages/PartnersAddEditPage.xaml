<Page x:Class="Uchebka.Pages.PartnersAddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchebka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="PartnersAddEditPage"
      Background="White">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Наименование</TextBlock>
                <TextBox Text="{Binding NamePartner}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Тип</TextBlock>
                <ComboBox x:Name="TypeCB" SelectedItem="{Binding TypeOfBusiness}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Адресс</TextBlock>
                <TextBox Text="{Binding UrAdress}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>ИНН</TextBlock>
                <TextBox Text="{Binding INN}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Фамилия</TextBlock>
                <TextBox Text="{Binding SurnameDirector}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Имя</TextBlock>
                <TextBox Text="{Binding NameDirector}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Отчество</TextBlock>
                <TextBox Text="{Binding PatronumicDirector}"/>
            </StackPanel>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Телефон</TextBlock>
                <TextBox Text="{Binding Phone}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Почта</TextBlock>
                <TextBox Text="{Binding Email}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock>Рейтинг</TextBlock>
                <TextBox Text="{Binding Raiting}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveBtn" Content="Сохранить" Click="SaveBtn_Click"/>
                <Button x:Name="CanselBtn" Content="Отмена" Click="CanselBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>

</Page>
